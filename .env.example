# Rename this file to .env and fill in your key.
# The pipeline uses Anthropic's Claude models by default.
ANTHROPIC_API_KEY=your_api_key_here

# Model used for extraction / summarization. Any current Claude model works;
# a small/fast model is usually enough for this task.
CLAUDE_MODEL=claude-sonnet-4-6

# Set to "true" to run the pipeline without calling the API (uses a
# deterministic dummy LLM). Useful for smoke-testing the pipeline end to end.
USE_MOCK_LLM=false
